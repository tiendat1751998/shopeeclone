{
  "title": "Kubernetes Cluster Overview",
  "version": 1,
  "panels": [
    {
      "title": "CPU Usage",
      "type": "timeseries",
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "sum(rate(container_cpu_usage_seconds_total{namespace=~\"shopee.*\"}[5m])) by (namespace)"
        }
      ]
    },
    {
      "title": "Memory Usage",
      "type": "timeseries",
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "sum(container_memory_working_set_bytes{namespace=~\"shopee.*\"}) by (namespace)"
        }
      ]
    },
    {
      "title": "Network I/O",
      "type": "timeseries",
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "sum(rate(container_network_receive_bytes_total{namespace=~\"shopee.*\"}[5m])) by (namespace)"
        },
        {
          "expr": "sum(rate(container_network_transmit_bytes_total{namespace=~\"shopee.*\"}[5m])) by (namespace)"
        }
      ]
    }
  ]
}
