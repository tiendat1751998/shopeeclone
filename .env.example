# ============================================
# Shopee Clone - Environment Configuration
# ============================================

# --- General ---
APP_ENV=development
APP_NAME=shopee-clone
LOG_LEVEL=debug

# --- PostgreSQL (Auth, Order, Payment) ---
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=shopee
POSTGRES_PASSWORD=shopee_dev
POSTGRES_DB=shopee

# --- MongoDB (Catalog) ---
MONGODB_URI=mongodb://localhost:27017/shopee_catalog
MONGODB_DATABASE=shopee_catalog

# --- Redis Cluster ---
REDIS_ADDR=localhost:6379
REDIS_PASSWORD=
REDIS_DB=0

# --- Kafka ---
KAFKA_BROKERS=localhost:9092
KAFKA_SCHEMA_REGISTRY=http://localhost:8081

# --- Elasticsearch ---
ELASTICSEARCH_URL=http://localhost:9200
ELASTICSEARCH_INDEX=shopee_products

# --- MinIO ---
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=shopee_access
MINIO_SECRET_KEY=shopee_secret
MINIO_BUCKET=shopee-assets

# --- JWT ---
JWT_ACCESS_SECRET=change-me-in-production
JWT_REFRESH_SECRET=change-me-too-in-production
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=168h
JWKS_ENDPOINT=http://identity-auth:8080/.well-known/jwks.json

# --- OpenTelemetry ---
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
OTEL_EXPORTER_OTLP_PROTOCOL=http/protobuf
OTEL_SERVICE_NAME=shopee-clone
OTEL_TRACES_SAMPLER=parentbased_traceidratio
OTEL_TRACES_SAMPLER_ARG=0.1

# --- Rate Limiting ---
RATE_LIMIT_REDIS_URL=localhost:6379
RATE_LIMIT_LOGIN_MAX=5
RATE_LIMIT_LOGIN_WINDOW=5m
RATE_LIMIT_CHECKOUT_MAX=1
RATE_LIMIT_CHECKOUT_WINDOW=5s
